{
  "name": "openshell",
  "displayName": "OpenShell",
  "description": "Registers the openshell CLI binary for managing sandboxed workspaces.",
  "version": "0.2.0-next",
  "icon": "icon.png",
  "publisher": "kaiden",
  "license": "Apache-2.0",
  "engines": {
    "kaiden": "^0.0.1"
  },
  "main": "./dist/extension.js",
  "source": "./src/extension.ts",
  "contributes": {
    "configuration": {
      "title": "OpenShell",
      "properties": {
        "openshell.binary.path": {
          "type": "string",
          "format": "file",
          "scope": "DEFAULT",
          "default": "",
          "description": "Custom path to OpenShell binary (Default is blank)"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "inversify": "^7.10.4"
  },
  "devDependencies": {
    "@openkaiden/api": "workspace:*",
    "vite": "^7.1.2",
    "vitest": "^4.0.10"
  }
}
