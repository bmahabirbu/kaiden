{
  "name": "openshift-ai",
  "displayName": "OpenShift AI",
  "description": "Integration for OpenShift AI",
  "version": "0.3.0-next",
  "icon": {
    "light": "icon_light.png",
    "dark": "icon_dark.png"
  },
  "publisher": "kaiden",
  "license": "Apache-2.0",
  "engines": {
    "kaiden": "^0.0.1"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "OpenShift AI",
      "properties": {
        "openshiftai.factory._description": {
          "type": "markdown",
          "scope": "InferenceProviderConnectionFactory",
          "markdownDescription": "Provide an OpenShift AI token. Please note that it is possible to have a token by login into the OpenShift AI console."
        },
        "openshiftai.factory.url": {
          "type": "string",
          "scope": "InferenceProviderConnectionFactory",
          "description": "OpenShift AI cluster API endpoint URL"
        },
        "openshiftai.factory.token": {
          "type": "string",
          "scope": "InferenceProviderConnectionFactory",
          "description": "Enter your OpenShift AI token",
          "format": "password"
        },
        "openshiftai.connection._type": {
          "type": "string",
          "scope": "InferenceProviderConnection",
          "description": "OpenShift AI provider type",
          "hidden": true
        },
        "openshiftai.connection.token": {
          "type": "string",
          "scope": "InferenceProviderConnection",
          "description": "API token secret reference",
          "format": "password",
          "hidden": true
        }
      }
    }
  },
  "scripts": {
    "build": "vite build && node ./scripts/build.js",
    "test": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest watch --coverage --passWithNoTests",
    "watch": "vite build --watch"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@openkaiden/api": "workspace:*",
    "@kubernetes/client-node": "^1.3.0"
  },
  "devDependencies": {
    "mkdirp": "^3.0.1",
    "vite": "^7.1.2",
    "vitest": "^4.0.10"
  }
}
